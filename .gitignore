# ─────────────────────────────────────────────────────────────────────────────
# Team Coding Death Match – .gitignore
# Monorepo: Go backend (backend/) + future frontend (frontend/)
# ─────────────────────────────────────────────────────────────────────────────


# ── Secrets & environment files ───────────────────────────────────────────────
# Never commit real credentials, JWT secrets, or DB passwords.
.env
**/.env
*.env
!*.env.example
!*.env.template

# Project-specific env files
backend/config/dev.env
backend/config/*.env
backend/config/prod.env
backend/config/staging.env



# ── Go build artifacts ────────────────────────────────────────────────────────
# Compiled binaries
backend/bin/
backend/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Go test output & coverage
*.out
coverage.html
coverage.txt
/tmp/

# Go module download cache (should not be committed)
# go.sum IS committed intentionally – do not ignore it


# ── Air / live-reload ─────────────────────────────────────────────────────────
# https://github.com/cosmtrek/air
backend/tmp/
.air.toml


# ── frontend (Node / Next.js / Vite / React) ──────────────────────────────────
*/node_modules/
*/.next/
*/out/
*/dist/
*/build/
*/.nuxt/
*/.output/
*/.cache/
*/.turbo/
*/.vercel/
*/.netlify/
*/storybook-static/
*/DESIGN.md

# Package manager lock files – keep ONE (whichever your team uses)
# Uncomment the one you do NOT use to ignore it:
*/package-lock.json
# frontend/yarn.lock
# frontend/pnpm-lock.yaml

# Env files inside frontend
*/.env
*/.env.local
*/.env.development.local
*/.env.test.local
*/.env.production.local


# ── IDE / editor ──────────────────────────────────────────────────────────────

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (GoLand, WebStorm, IntelliJ …)
.idea/
*.iml
*.ipr
*.iws

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# Zed
.zed/


# ── OS-generated files ────────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
.directory
.Trash-*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


# ── Docker ────────────────────────────────────────────────────────────────────
# Local override compose files that may contain secrets
docker-compose.override.yml
docker-compose.local.yml

# Docker volumes mounted locally (postgres data, redis data, etc.)
.docker/
docker/data/
postgres-data/
redis-data/


# ── Database ──────────────────────────────────────────────────────────────────
# Local PostgreSQL data directory if running bare-metal
pgdata/
*.pgsql
*.sql.bak

# SQLite (if used in tests)
*.sqlite
*.sqlite3
*.db


# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
backend/logs/
frontend/logs/


# ── Profiling & debug ─────────────────────────────────────────────────────────
# Go pprof output
*.pprof
cpu.prof
mem.prof

# Delve debugger
__debug_bin
__debug_bin*


# ── Test & tooling output ─────────────────────────────────────────────────────
# Testify / gotestsum reports
test-results/
junit.xml

# golangci-lint cache
.golangci-lint-cache/
.golangci.yml.cache

# mockery generated mocks (if auto-generated; remove if you commit mocks)
# mocks/


# ── Miscellaneous ─────────────────────────────────────────────────────────────
# Compiled proto files (if generated; remove if you commit them)
# *.pb.go

# Vendor directory (remove if you use `go mod vendor`)
# vendor/
